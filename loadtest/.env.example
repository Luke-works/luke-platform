# Copy to .env and `set -a; source .env; set +a` before running, or pass each as -e to k6.

# Where the form API (/api/form-instances) is served.
#   today (split):  the capability service URL
#   post-merge:     the core engine URL
BASE_URL=https://platform-qa-engine.onrender.com

# Where /engine-rest lives (always the core engine). Often same host post-merge.
ENGINE_URL=https://platform-qa-engine.onrender.com

# Tenant + user the test acts as (header-trusted when the auth gateway is off).
TENANT_ID=loadtest
USER_ID=loadtest-user

# A published form's code (from setup.sh, or an existing one).
FORM_CODE=loadtest-form

# Auth for /api/*  — only needed if the staged engine has the gateway ENABLED.
# Leave blank when LUKE_AUTH_GATEWAY_ENABLED=false on the staged engine.
# AUTH_HEADER=Bearer <act-as-user-jwt>

# Auth for /engine-rest/* (monitor + engine_start scenario): Basic admin creds.
ENGINE_BASIC=admin:admin
# or: ENGINE_AUTH=Basic <base64 user:pass>

# Load shape
MAX_RATE=50      # peak target requests/sec to ramp to
STAGE_SEC=30     # seconds per ramp stage
SCENARIO=submit_flow   # submit_flow | engine_start | all
PROC_KEY=FormSubmissionIntakeProcess
